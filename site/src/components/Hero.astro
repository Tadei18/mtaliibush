---
import { Image } from 'astro:assets';
import heroImage from '../assets/hero/hero-mt-kenya.jpg';
import heroAmbientPoster from '../assets/hero/hero-mt-kenya.jpg';
import logoWhite from '../assets/brand/mtalii-logo-white.png';
import CTAButton from './CTAButton.astro';

// Hero ambient video — generated by scripts/compress-videos.mjs from Reels/trip.mp4.
// Imported eagerly so vite includes it in the build; the <video> element is the
// gatekeeper for actual playback (lazy via IntersectionObserver + reduced-motion guard).
const ambientSrc = '/video/hero-ambient.mp4';
---
<section
  id="hero"
  class="relative h-[100svh] min-h-[640px] overflow-hidden bg-forest-deep text-cream"
  data-hero-parallax
>
  <!-- Background photograph: covers the full viewport with subtle zoom + parallax -->
  <div class="hero-bg absolute inset-0 z-0 will-change-transform">
    <Image
      src={heroImage}
      alt="Golden-hour view of Mtalii Bush Camps tents with Mount Kenya rising in the distance"
      widths={[960, 1440, 1920, 2400]}
      sizes="100vw"
      quality={82}
      format="webp"
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 h-[112%] w-full object-cover animate-subtle-zoom"
    />
  </div>

  <!-- Ambient video — sits above the photo, fades in once it can play.
       Hidden until JS opts it in: respects prefers-reduced-motion + slow connections. -->
  <video
    id="hero-ambient"
    class="hero-ambient absolute inset-0 z-[1] h-full w-full object-cover opacity-0 transition-opacity duration-[1200ms] ease-editorial"
    autoplay
    muted
    loop
    playsinline
    preload="none"
    poster={heroImage.src}
    data-ambient-src={ambientSrc}
    aria-hidden="true"
  ></video>

  <!-- Editorial gradient overlays -->
  <div class="absolute inset-0 z-10 bg-[radial-gradient(120%_80%_at_50%_120%,rgba(15,68,35,0.65),rgba(15,68,35,0.15)_45%,transparent_75%)]"></div>
  <div class="absolute inset-0 z-10 bg-gradient-to-b from-forest-deep/55 via-transparent to-forest-deep/40"></div>
  <div class="absolute inset-x-0 top-0 z-10 h-40 bg-gradient-to-b from-forest-deep/70 to-transparent"></div>

  <!-- Foreground content -->
  <div class="relative z-20 flex h-full flex-col items-center justify-center px-6 text-center">
    <h1 class="sr-only">Mtalii Bush Camps — luxury tented safari camp at the foothills of Mount Kenya</h1>

    <p
      class="reveal reveal--fade-up font-body font-semibold uppercase tracking-[0.42em] text-[0.72rem] text-sand"
      style="--reveal-delay:200ms;"
      aria-hidden="true"
    >
      Nanyuki &middot; Mt. Kenya &middot; Kenya
    </p>

    <div class="reveal reveal--fade mt-8" style="--reveal-delay:350ms;" aria-hidden="true">
      <Image
        src={logoWhite}
        alt=""
        widths={[360, 540, 720]}
        sizes="(min-width: 768px) 540px, 70vw"
        quality={92}
        loading="eager"
        fetchpriority="high"
        class="mx-auto h-auto w-[18rem] md:w-[28rem] lg:w-[34rem]"
      />
    </div>

    <p
      class="reveal reveal--fade-up mt-10 max-w-2xl font-display italic text-xl md:text-3xl text-cream/95 leading-snug text-balance"
      style="--reveal-delay:600ms;"
    >
      A boutique tented retreat where the wilderness meets fine dining, and strangers become friends around the fire.
    </p>

    <div class="reveal reveal--fade-up mt-12 flex flex-col sm:flex-row items-center gap-4" style="--reveal-delay:800ms;">
      <CTAButton href="/contact" variant="primary" tone="dark">Plan Your Stay</CTAButton>
      <CTAButton href="#story" variant="outline" tone="dark">Explore the Camp</CTAButton>
    </div>
  </div>

  <!-- Scroll cue -->
  <a
    href="#story"
    aria-label="Scroll to story"
    class="absolute bottom-8 left-1/2 z-30 -translate-x-1/2 text-cream/80 hover:text-sand transition-colors"
  >
    <span class="block font-body uppercase tracking-[0.32em] text-[0.62rem] mb-3 text-center">Scroll</span>
    <span class="scroll-cue mx-auto block h-12 w-px bg-gradient-to-b from-cream/80 to-transparent"></span>
  </a>
</section>
