---
/**
 * Booking-first enquiry bar — overlaid at the foot of the hero.
 *
 * Visual concept: a pane of "liquid glass" floating on the turquoise water of
 * the camp's guitar-shaped infinity pool. Glassmorphism (backdrop blur +
 * saturate), a specular rim-light, slow-drifting caustics, an occasional
 * diagonal sheen, a gentle idle bob, and water-droplet ripples on focus/click.
 * Aqua is an accent blended into the brand cream/sand — legibility first, so
 * all label/input text stays forest/coffee/ink over the glass.
 *
 * We have no live booking engine, so "Check Availability" routes to /contact
 * with the chosen values passed as query params (checkin, checkout, guests),
 * which the EnquiryForm reads and pre-fills.
 *
 * Layout (unchanged + verified): centred via auto margins, capped at
 * min(60rem, 100% - 2rem) so it never exceeds the viewport; the three fields
 * use minmax(0,1fr) + min-width:0 so native date inputs shrink instead of
 * overflowing, and the submit (flex:none) stays visible / wraps before clipping.
 * Mobile collapses to a single "Check Availability" pill.
 *
 * prefers-reduced-motion: all motion (caustics, sheen, bob, ripple, fade) is
 * disabled — falls back to a clean static frosted-glass bar.
 * @supports: where backdrop-filter is unsupported, a solid translucent cream bar.
 */
---
<div class="enquiry-bar" data-enquiry-bar>
  <!-- Mobile trigger — single glass pill that toggles the field sheet -->
  <button
    type="button"
    class="enquiry-bar__trigger"
    aria-expanded="false"
    aria-controls="enquiry-fields"
    data-enquiry-trigger
    data-eb-ripple-host
  >
    <span class="eb-fx" aria-hidden="true">
      <span class="eb-caustics"></span>
      <span class="eb-sheen"></span>
    </span>
    <span class="enquiry-bar__trigger-inner">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4.5" width="18" height="16" rx="2" /><path d="M3 9h18M8 2.5v4M16 2.5v4" />
      </svg>
      Check Availability
    </span>
  </button>

  <form
    id="enquiry-fields"
    class="enquiry-bar__form"
    action="/contact"
    method="get"
    data-enquiry-form
    data-eb-ripple-host
  >
    <!-- Decorative glass FX layer (absolutely positioned — never a flex item) -->
    <span class="eb-fx" aria-hidden="true" data-eb-fx>
      <span class="eb-caustics"></span>
      <span class="eb-sheen"></span>
    </span>

    <div class="enquiry-bar__fields">
      <div class="enquiry-bar__field">
        <label class="enquiry-bar__label" for="eb-checkin">Check&#8209;in</label>
        <input type="date" id="eb-checkin" name="checkin" class="enquiry-bar__input" data-eb-checkin data-eb-focus />
      </div>

      <div class="enquiry-bar__field">
        <label class="enquiry-bar__label" for="eb-checkout">Check&#8209;out</label>
        <input type="date" id="eb-checkout" name="checkout" class="enquiry-bar__input" data-eb-checkout data-eb-focus />
      </div>

      <div class="enquiry-bar__field">
        <label class="enquiry-bar__label" for="eb-guests">Guests</label>
        <input type="number" id="eb-guests" name="guests" min="1" max="1000" inputmode="numeric" placeholder="2" class="enquiry-bar__input" data-eb-focus />
      </div>
    </div>

    <button type="submit" class="enquiry-bar__submit" data-eb-ripple-host data-eb-submit>
      <span class="enquiry-bar__submit-label">
        Check Availability
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </button>
  </form>
</div>

<style is:global>
  .enquiry-bar {
    position: absolute;
    /* Centre via auto margins (NOT translateX) so the fade animation's
       transform on this same element can't clobber the horizontal centring. */
    left: 0;
    right: 0;
    margin-inline: auto;
    bottom: clamp(1.25rem, 4vh, 2.75rem);
    z-index: 30;
    /* Hard-capped — never wider than the viewport minus side padding */
    width: min(60rem, calc(100% - 2rem));
    /* Fade in on load — NOT via the scroll IntersectionObserver, which would
       leave the bar invisible at the foot of an unscrolled hero. */
    opacity: 0;
    animation: eb-fade-in 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.8s forwards;
  }
  @keyframes eb-fade-in {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Shared liquid-glass surface ─────────────────────────────────────── */
  .enquiry-bar__form,
  .enquiry-bar__trigger {
    position: relative;
    isolation: isolate;
    /* Cream-dominant so text stays legible, with a whisper of aqua water */
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.32), rgba(255, 255, 255, 0.04)),
      linear-gradient(180deg, rgba(248, 252, 251, 0.82), rgba(245, 248, 244, 0.78));
    -webkit-backdrop-filter: blur(18px) saturate(1.35);
    backdrop-filter: blur(18px) saturate(1.35);
    border: 1px solid rgba(255, 255, 255, 0.45);
    /* Layered float shadow + specular rim-light (top/left) + aqua inner glow */
    box-shadow:
      0 26px 60px -28px rgba(15, 68, 35, 0.55),
      0 4px 14px -6px rgba(15, 68, 35, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.7),
      inset 1px 0 0 rgba(255, 255, 255, 0.32),
      inset 0 0 30px rgba(150, 224, 214, 0.18);
  }

  /* Glass FX layer — clips caustics / sheen / ripples to the rounded shape */
  .eb-fx {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    border-radius: inherit;
    pointer-events: none;
  }
  .eb-caustics {
    position: absolute;
    inset: -25%;
    background:
      radial-gradient(38% 30% at 22% 32%, rgba(126, 222, 214, 0.30), transparent 62%),
      radial-gradient(34% 26% at 68% 58%, rgba(150, 232, 206, 0.24), transparent 62%),
      radial-gradient(30% 38% at 48% 82%, rgba(110, 206, 224, 0.20), transparent 62%),
      radial-gradient(26% 22% at 85% 22%, rgba(180, 240, 224, 0.18), transparent 60%);
    filter: blur(10px);
    mix-blend-mode: screen;
    will-change: transform;
    animation: eb-caustic-drift 16s ease-in-out infinite alternate;
  }
  .eb-sheen {
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg, transparent 32%, rgba(255, 255, 255, 0.5) 48%, rgba(255, 255, 255, 0) 60%);
    transform: translateX(-130%);
    will-change: transform;
    animation: eb-sheen 9s ease-in-out 2.5s infinite;
  }
  @keyframes eb-caustic-drift {
    0%   { transform: translate3d(-3%, -2%, 0) scale(1.04); }
    100% { transform: translate3d(3%, 2%, 0) scale(1.12); }
  }
  @keyframes eb-sheen {
    0%, 72%   { transform: translateX(-130%); }
    88%, 100% { transform: translateX(130%); }
  }

  /* Water-droplet ripple (added by JS on focus / click) */
  .eb-ripple {
    position: absolute;
    width: 18rem;
    height: 18rem;
    border-radius: 50%;
    pointer-events: none;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.5), rgba(150, 230, 220, 0.28) 38%, transparent 70%);
    transform: translate(-50%, -50%) scale(0);
    opacity: 0.9;
    animation: eb-ripple 0.95s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .eb-ripple--gold {
    background: radial-gradient(circle, rgba(255, 246, 224, 0.7), rgba(228, 192, 132, 0.45) 38%, transparent 70%);
  }
  @keyframes eb-ripple {
    to { transform: translate(-50%, -50%) scale(1); opacity: 0; }
  }

  /* Idle float — the pane resting on water (on the glass, not the wrapper, so
     it can't fight the wrapper's fade-in transform) */
  @media (min-width: 1024px) {
    .enquiry-bar__form { animation: eb-bob 6.5s ease-in-out 1.8s infinite; }
  }
  .enquiry-bar__trigger { animation: eb-bob 6.5s ease-in-out 1.8s infinite; }
  @keyframes eb-bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  /* ── Desktop bar form ────────────────────────────────────────────────── */
  .enquiry-bar__form {
    display: none; /* shown per-breakpoint below */
  }
  @media (min-width: 1024px) {
    .enquiry-bar__form {
      display: flex;
      flex-wrap: wrap;
      align-items: stretch;
      gap: 0.5rem;
      padding: 0.5rem;
      border-radius: 999px;
    }
  }

  /* Field group — grows to fill the bar, shrinks to nothing before clipping */
  .enquiry-bar__fields {
    position: relative;
    z-index: 1;
    flex: 1 1 22rem;
    min-width: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: stretch;
  }

  .enquiry-bar__field {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0; /* allow the column to shrink */
    padding: 0.5rem 1.25rem;
  }
  .enquiry-bar__field + .enquiry-bar__field {
    border-left: 1px solid rgba(96, 60, 12, 0.18);
  }
  .enquiry-bar__label {
    font-family: 'Mulish', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: #6B4410; /* coffee — high contrast on the glass */
    margin-bottom: 0.2rem;
    white-space: nowrap;
  }
  .enquiry-bar__input {
    width: 100%;
    min-width: 0; /* critical: let native date inputs shrink inside the grid */
    background: transparent;
    border: 0;
    padding: 0;
    font-family: 'Mulish', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: #241C12; /* ink */
    line-height: 1.3;
  }
  .enquiry-bar__input::placeholder { color: rgba(36, 28, 18, 0.45); font-weight: 500; }
  .enquiry-bar__input:focus { outline: none; }
  .enquiry-bar__input:focus-visible { outline: 2px solid #186030; outline-offset: 4px; border-radius: 4px; }
  /* Native date controls — keep the calendar picker reachable, tidy the text */
  .enquiry-bar__input[type='date'] { min-height: 1.3rem; color-scheme: light; }

  .enquiry-bar__submit {
    position: relative;
    z-index: 1;
    flex: 0 0 auto; /* always visible; wraps to its own row before clipping */
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: #E4C084;
    cursor: pointer;
    /* Gloss: top specular highlight + soft drop */
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.6),
      inset 0 -1px 0 rgba(96, 60, 12, 0.18),
      0 8px 18px -8px rgba(96, 60, 12, 0.5);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease;
  }
  /* Liquid fill — a gold wave rises on hover/focus */
  .enquiry-bar__submit::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(to top, #BE9856, #E9CB92);
    transform: translateY(101%);
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .enquiry-bar__submit:hover::before,
  .enquiry-bar__submit:focus-visible::before { transform: translateY(0); }
  .enquiry-bar__submit-label {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 1.6rem;
    color: #241C12;
    font-family: 'Mulish', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    white-space: nowrap;
  }
  .enquiry-bar__submit-label svg { transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1); }
  .enquiry-bar__submit:hover { transform: translateY(-1px); }
  .enquiry-bar__submit:hover .enquiry-bar__submit-label svg { transform: translateX(3px); }
  .enquiry-bar__submit:focus-visible { outline: 2px solid #186030; outline-offset: 3px; }

  /* ── Mobile glass pill trigger ───────────────────────────────────────── */
  .enquiry-bar__trigger {
    display: block;
    width: 100%;
    border-radius: 999px;
    cursor: pointer;
    overflow: hidden;
  }
  .enquiry-bar__trigger-inner {
    position: relative;
    z-index: 1;
    display: inline-flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    padding: 1.05rem 1.5rem;
    color: #186030; /* forest — legible on glass */
    font-family: 'Mulish', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }
  .enquiry-bar__trigger:focus-visible { outline: 2px solid #186030; outline-offset: 3px; }
  /* Trigger is mobile/tablet only — the full bar takes over at lg.
     Controlled here (not Tailwind lg:hidden) so component styles can't
     override the utility in the cascade. */
  @media (min-width: 1024px) {
    .enquiry-bar__trigger { display: none; }
  }

  /* Mobile expanded sheet (below lg) */
  @media (max-width: 1023.98px) {
    .enquiry-bar[data-open='true'] .enquiry-bar__form {
      display: block;
      margin-bottom: 0.75rem;
      padding: 1rem 1.25rem 1.25rem;
      border-radius: 1.25rem;
      animation: none; /* no bob on the open sheet */
    }
    .enquiry-bar[data-open='true'] .enquiry-bar__fields {
      grid-template-columns: 1fr;
    }
    .enquiry-bar[data-open='true'] .enquiry-bar__field {
      padding: 0.65rem 0;
      border-left: 0;
    }
    .enquiry-bar[data-open='true'] .enquiry-bar__field + .enquiry-bar__field {
      border-top: 1px solid rgba(96, 60, 12, 0.14);
    }
    .enquiry-bar__submit {
      width: 100%;
      margin-top: 0.85rem;
    }
    .enquiry-bar__submit-label { width: 100%; justify-content: center; }
  }

  /* ── Performance: simplify the heaviest effects on small / low-power ──── */
  @media (max-width: 640px) {
    .eb-caustics { display: none; }
    .eb-sheen { animation-duration: 12s; }
    .enquiry-bar__form,
    .enquiry-bar__trigger {
      -webkit-backdrop-filter: blur(12px) saturate(1.25);
      backdrop-filter: blur(12px) saturate(1.25);
    }
  }

  /* ── No backdrop-filter support → solid translucent cream bar ─────────── */
  @supports not ((backdrop-filter: blur(2px)) or (-webkit-backdrop-filter: blur(2px))) {
    .enquiry-bar__form,
    .enquiry-bar__trigger {
      background: rgba(251, 245, 236, 0.96);
    }
    .eb-caustics { opacity: 0.6; }
  }

  /* ── Reduced motion → clean static frosted glass ─────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .enquiry-bar { animation: none; opacity: 1; transform: none; }
    .enquiry-bar__form,
    .enquiry-bar__trigger { animation: none; }
    .eb-caustics,
    .eb-sheen { display: none; }
    .eb-ripple { display: none; }
    .enquiry-bar__submit,
    .enquiry-bar__submit::before,
    .enquiry-bar__submit-label svg { transition: none; }
  }
</style>

<script>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const root = document.querySelector<HTMLElement>('[data-enquiry-bar]');
  if (root) {
    const trigger = root.querySelector<HTMLButtonElement>('[data-enquiry-trigger]');
    const form = root.querySelector<HTMLFormElement>('[data-enquiry-form]');
    const checkin = root.querySelector<HTMLInputElement>('[data-eb-checkin]');
    const checkout = root.querySelector<HTMLInputElement>('[data-eb-checkout]');

    // Sensible date floors — can't check in before today; check-out after check-in
    const today = new Date().toISOString().split('T')[0];
    if (checkin) checkin.min = today;
    if (checkout) checkout.min = today;
    checkin?.addEventListener('change', () => {
      if (checkout && checkin.value) {
        checkout.min = checkin.value;
        if (checkout.value && checkout.value < checkin.value) checkout.value = checkin.value;
      }
    });

    // Mobile expand / collapse
    trigger?.addEventListener('click', () => {
      const open = root.getAttribute('data-open') === 'true';
      root.setAttribute('data-open', String(!open));
      trigger.setAttribute('aria-expanded', String(!open));
    });

    // ── Water-droplet ripple (decorative only; never replaces focus rings) ──
    const spawnRipple = (host: HTMLElement, x: number, y: number, gold = false) => {
      if (prefersReducedMotion) return;
      const fx = host.querySelector<HTMLElement>('.eb-fx');
      const layer = fx ?? host; // submit has no .eb-fx; it clips its own overflow
      const ripple = document.createElement('span');
      ripple.className = gold ? 'eb-ripple eb-ripple--gold' : 'eb-ripple';
      const rect = host.getBoundingClientRect();
      ripple.style.left = `${x - rect.left}px`;
      ripple.style.top = `${y - rect.top}px`;
      layer.appendChild(ripple);
      ripple.addEventListener('animationend', () => ripple.remove());
    };

    // Ripple from the point of interaction on click (pointer coords)
    root.querySelectorAll<HTMLElement>('[data-eb-ripple-host]').forEach((host) => {
      host.addEventListener('pointerdown', (e) => {
        const gold = host.hasAttribute('data-eb-submit');
        spawnRipple(host, e.clientX, e.clientY, gold);
      });
    });

    // Ripple from the centre of a field on keyboard/programmatic focus
    root.querySelectorAll<HTMLElement>('[data-eb-focus]').forEach((input) => {
      input.addEventListener('focus', () => {
        const host = input.closest<HTMLElement>('[data-eb-ripple-host]');
        if (!host) return;
        const r = input.getBoundingClientRect();
        spawnRipple(host, r.left + r.width / 2, r.top + r.height / 2);
      });
    });

    // Build a clean /contact URL — drop empty params so we never pass blanks
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const params = new URLSearchParams();
      const fd = new FormData(form);
      for (const [key, value] of fd.entries()) {
        const v = String(value).trim();
        if (v) params.set(key, v);
      }
      const qs = params.toString();
      window.location.href = qs ? `/contact?${qs}` : '/contact';
    });
  }
</script>
