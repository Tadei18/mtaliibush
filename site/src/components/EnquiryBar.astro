---
/**
 * Booking-first enquiry bar — overlaid at the foot of the hero.
 *
 * We have no live booking engine, so "Check Availability" routes to /contact
 * with the chosen values passed as query params (checkin, checkout, guests),
 * which the EnquiryForm reads and pre-fills.
 *
 * Desktop: a horizontal glass/cream card split into date + guest segments.
 * Mobile: collapses to a single "Check Availability" pill that expands the
 * same fields in a sheet above it.
 */
---
<div class="enquiry-bar reveal reveal--fade-up" style="--reveal-delay:1000ms;" data-enquiry-bar>
  <!-- Mobile trigger — single pill that toggles the field sheet -->
  <button
    type="button"
    class="enquiry-bar__trigger"
    aria-expanded="false"
    aria-controls="enquiry-fields"
    data-enquiry-trigger
  >
    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="4.5" width="18" height="16" rx="2" /><path d="M3 9h18M8 2.5v4M16 2.5v4" />
    </svg>
    Check Availability
  </button>

  <form
    id="enquiry-fields"
    class="enquiry-bar__form"
    action="/contact"
    method="get"
    data-enquiry-form
  >
    <div class="enquiry-bar__field">
      <label class="enquiry-bar__label" for="eb-checkin">Check&#8209;in</label>
      <input type="date" id="eb-checkin" name="checkin" class="enquiry-bar__input" data-eb-checkin />
    </div>

    <span class="enquiry-bar__divider" aria-hidden="true"></span>

    <div class="enquiry-bar__field">
      <label class="enquiry-bar__label" for="eb-checkout">Check&#8209;out</label>
      <input type="date" id="eb-checkout" name="checkout" class="enquiry-bar__input" data-eb-checkout />
    </div>

    <span class="enquiry-bar__divider" aria-hidden="true"></span>

    <div class="enquiry-bar__field">
      <label class="enquiry-bar__label" for="eb-guests">Guests</label>
      <input type="number" id="eb-guests" name="guests" min="1" max="1000" inputmode="numeric" placeholder="2" class="enquiry-bar__input" />
    </div>

    <button type="submit" class="enquiry-bar__submit">
      <span>Check Availability</span>
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </form>
</div>

<style is:global>
  .enquiry-bar {
    position: absolute;
    left: 50%;
    bottom: clamp(1.25rem, 4vh, 2.75rem);
    transform: translateX(-50%);
    z-index: 30;
    width: min(64rem, calc(100% - 2rem));
  }

  /* The cream/glass card */
  .enquiry-bar__form {
    display: none;
    grid-template-columns: 1fr auto 1fr auto 1fr auto;
    align-items: stretch;
    gap: 0;
    padding: 0.5rem 0.5rem 0.5rem 1.5rem;
    border-radius: 999px;
    background: rgba(251, 245, 236, 0.82);
    backdrop-filter: blur(18px) saturate(1.1);
    -webkit-backdrop-filter: blur(18px) saturate(1.1);
    border: 1px solid rgba(228, 192, 132, 0.55);
    box-shadow: 0 24px 60px -28px rgba(15, 68, 35, 0.55);
  }
  @media (min-width: 1024px) {
    .enquiry-bar__form { display: grid; }
  }

  .enquiry-bar__field {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0.5rem 1.25rem;
    min-width: 0;
  }
  .enquiry-bar__label {
    font-family: 'Mulish', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: #7A4E1B;
    margin-bottom: 0.2rem;
  }
  .enquiry-bar__input {
    width: 100%;
    background: transparent;
    border: 0;
    padding: 0;
    font-family: 'Mulish', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: #241C12;
    line-height: 1.3;
  }
  .enquiry-bar__input::placeholder { color: rgba(36, 28, 18, 0.4); font-weight: 500; }
  .enquiry-bar__input:focus { outline: none; }
  .enquiry-bar__input:focus-visible { outline: 2px solid #186030; outline-offset: 4px; border-radius: 4px; }
  /* Native date controls — keep the calendar picker reachable, tidy the text */
  .enquiry-bar__input[type='date'] { min-height: 1.3rem; color-scheme: light; }

  .enquiry-bar__divider {
    width: 1px;
    align-self: center;
    height: 2.25rem;
    background: rgba(96, 60, 12, 0.18);
  }

  .enquiry-bar__submit {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-left: 0.5rem;
    padding: 0 1.75rem;
    border: 0;
    border-radius: 999px;
    background: #E4C084;
    color: #241C12;
    font-family: 'Mulish', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.4s cubic-bezier(0.22, 1, 0.36, 1), transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .enquiry-bar__submit svg { transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1); }
  .enquiry-bar__submit:hover { background: #C9A461; }
  .enquiry-bar__submit:hover svg { transform: translateX(3px); }
  .enquiry-bar__submit:focus-visible { outline: 2px solid #FBF5EC; outline-offset: 3px; }

  /* Mobile pill trigger */
  .enquiry-bar__trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    width: 100%;
    padding: 1.05rem 1.5rem;
    border: 1px solid rgba(228, 192, 132, 0.6);
    border-radius: 999px;
    background: rgba(251, 245, 236, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    color: #186030;
    font-family: 'Mulish', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    cursor: pointer;
    box-shadow: 0 20px 45px -24px rgba(15, 68, 35, 0.6);
  }
  .enquiry-bar__trigger:focus-visible { outline: 2px solid #E4C084; outline-offset: 3px; }
  /* Trigger is mobile/tablet only — the full bar takes over at lg.
     Controlled here (not via Tailwind lg:hidden) so component styles can't
     override the utility in the cascade. */
  @media (min-width: 1024px) {
    .enquiry-bar__trigger { display: none; }
  }

  /* Mobile expanded sheet */
  @media (max-width: 1023.98px) {
    .enquiry-bar[data-open='true'] .enquiry-bar__form {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.25rem;
      margin-bottom: 0.75rem;
      padding: 1rem 1.25rem 1.25rem;
      border-radius: 1.25rem;
    }
    .enquiry-bar__form .enquiry-bar__divider { display: none; }
    .enquiry-bar[data-open='true'] .enquiry-bar__field {
      padding: 0.65rem 0;
      border-bottom: 1px solid rgba(96, 60, 12, 0.14);
    }
    .enquiry-bar__submit {
      width: 100%;
      justify-content: center;
      margin-left: 0;
      margin-top: 0.85rem;
      padding-top: 0.95rem;
      padding-bottom: 0.95rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .enquiry-bar__submit, .enquiry-bar__submit svg { transition: none; }
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-enquiry-bar]');
  if (root) {
    const trigger = root.querySelector<HTMLButtonElement>('[data-enquiry-trigger]');
    const form = root.querySelector<HTMLFormElement>('[data-enquiry-form]');
    const checkin = root.querySelector<HTMLInputElement>('[data-eb-checkin]');
    const checkout = root.querySelector<HTMLInputElement>('[data-eb-checkout]');

    // Sensible date floors — can't check in before today; check-out after check-in
    const today = new Date().toISOString().split('T')[0];
    if (checkin) checkin.min = today;
    if (checkout) checkout.min = today;
    checkin?.addEventListener('change', () => {
      if (checkout && checkin.value) {
        checkout.min = checkin.value;
        if (checkout.value && checkout.value < checkin.value) checkout.value = checkin.value;
      }
    });

    // Mobile expand / collapse
    trigger?.addEventListener('click', () => {
      const open = root.getAttribute('data-open') === 'true';
      root.setAttribute('data-open', String(!open));
      trigger.setAttribute('aria-expanded', String(!open));
    });

    // Build a clean /contact URL — drop empty params so we never pass blanks
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const params = new URLSearchParams();
      const fd = new FormData(form);
      for (const [key, value] of fd.entries()) {
        const v = String(value).trim();
        if (v) params.set(key, v);
      }
      const qs = params.toString();
      window.location.href = qs ? `/contact?${qs}` : '/contact';
    });
  }
</script>
