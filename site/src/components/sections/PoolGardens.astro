---
import { Image } from 'astro:assets';
import Kicker from '../Kicker.astro';
import poolAerial from '../../assets/pool/guitar-pool-aerial.jpg';
import poolMtKenya from '../../assets/pool/guitar-pool-mt-kenya.jpg';
---
<section id="pool" class="relative bg-forest-deep text-cream py-24 md:py-36 overflow-hidden">
  <!-- Atmospheric overlay -->
  <span class="pointer-events-none absolute inset-0 bg-[radial-gradient(80%_60%_at_50%_0%,rgba(228,192,132,0.12),transparent_70%)]"></span>

  <div class="relative mx-auto max-w-wide px-6 md:px-10">
    <div class="grid items-end gap-12 md:grid-cols-12 md:gap-16 mb-12 md:mb-20">
      <div class="md:col-span-7">
        <div class="reveal reveal--fade-up"><Kicker tone="sand">Slow Intentional Leisure</Kicker></div>
        <h2 class="reveal reveal--fade-up mt-7 font-display text-display-lg text-cream text-balance" style="--reveal-delay:100ms;">
          A guitar-shaped infinity pool, tuned to Mt.&nbsp;Kenya.
        </h2>
      </div>
      <div class="md:col-span-5 prose-editorial md:pb-2">
        <p class="reveal reveal--fade-up text-cream/85" style="--reveal-delay:200ms;">
          A thoughtfully designed outdoor space anchored by a striking guitar-shaped infinity pool,
          with private cabanas offering discreet, personalised service. From afternoon teas served
          daily at 4pm to Sunday brunches, this space captures the spirit of slow, intentional
          leisure.
        </p>
      </div>
    </div>

    <!-- Two-image composition -->
    <div class="grid grid-cols-12 gap-4 md:gap-6">
      <figure class="reveal reveal--scale-image col-span-12 md:col-span-8 relative overflow-hidden aspect-[16/10]">
        <Image
          src={poolAerial}
          alt="Aerial view of the guitar-shaped infinity pool at Mtalii Bush Camps"
          widths={[640, 1024, 1440, 1920]}
          sizes="(min-width:768px) 66vw, 100vw"
          quality={82}
          format="webp"
          loading="lazy"
          class="absolute inset-0 h-full w-full object-cover"
        />
      </figure>
      <figure class="reveal reveal--scale-image col-span-12 md:col-span-4 relative overflow-hidden aspect-[3/4]" style="--reveal-delay:150ms;">
        <Image
          src={poolMtKenya}
          alt="Pool fretboard reaching toward the silhouette of Mt. Kenya"
          widths={[480, 720, 960]}
          sizes="(min-width:768px) 34vw, 100vw"
          quality={82}
          format="webp"
          loading="lazy"
          class="absolute inset-0 h-full w-full object-cover"
        />
      </figure>
    </div>

    <!-- Small ritual / time strip -->
    <div class="reveal reveal--fade-up mt-14 grid gap-px bg-cream/15 md:grid-cols-3 max-w-3xl mx-auto" style="--reveal-delay:200ms;">
      <div class="bg-forest-deep px-6 py-7 text-center">
        <p class="font-display italic text-2xl text-sand">4&nbsp;pm</p>
        <p class="mt-2 font-body uppercase tracking-[0.24em] text-[0.66rem] text-cream/70">Afternoon Teas</p>
      </div>
      <div class="bg-forest-deep px-6 py-7 text-center">
        <p class="font-display italic text-2xl text-sand">Sundays</p>
        <p class="mt-2 font-body uppercase tracking-[0.24em] text-[0.66rem] text-cream/70">Long Brunches</p>
      </div>
      <div class="bg-forest-deep px-6 py-7 text-center">
        <p class="font-display italic text-2xl text-sand">All&nbsp;Day</p>
        <p class="mt-2 font-body uppercase tracking-[0.24em] text-[0.66rem] text-cream/70">Private Cabanas</p>
      </div>
    </div>
  </div>
</section>
