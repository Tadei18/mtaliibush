---
import { Image } from 'astro:assets';
import Kicker from '../Kicker.astro';
import IconGrid from '../IconGrid.astro';
import tentExterior from '../../assets/accommodation/tent-exterior.jpg';
import tentHottub from '../../assets/accommodation/tent-with-hottub.jpg';
import tentInterior from '../../assets/accommodation/tent-interior.jpg';

const peaks = [
  { num: '01', name: 'Nelion', subtitle: 'The Watchman' },
  { num: '02', name: 'Lenana', subtitle: 'The Companion' },
  { num: '03', name: 'Batian', subtitle: 'The Elder' },
];

const features = [
  { icon: 'bed', label: 'King-size & twin beds', desc: 'Plush, hand-finished linen with a choice of bed configuration.' },
  { icon: 'bath', label: 'Outdoor soaking bathtubs', desc: 'Star-lit baths cocooned by canvas and bush garden.' },
  { icon: 'leaf', label: 'Open-air rainforest showers', desc: 'Warm water under the open sky, surrounded by birdsong.' },
  { icon: 'desk', label: 'Lockable safes & vanity desks', desc: 'Quiet workspaces, luggage racks, and considered detail throughout.' },
];
---
<section id="stay" class="relative bg-cream py-24 md:py-36">
  <div class="mx-auto max-w-wide px-6 md:px-10">
    <header class="grid gap-12 md:grid-cols-12 md:gap-20 mb-16 md:mb-24">
      <div class="md:col-span-5">
        <div class="reveal reveal--fade-up"><Kicker tone="coffee">Stay With Us</Kicker></div>
        <h2 class="reveal reveal--fade-up mt-7 font-display text-display-lg text-forest text-balance" style="--reveal-delay:100ms;">
          Three villages, named for the peaks that hold them.
        </h2>
      </div>
      <div class="md:col-span-6 md:col-start-7 prose-editorial">
        <div class="reveal reveal--fade-up" style="--reveal-delay:150ms;">
          <p>
            Each tented village is themed after Mt.&nbsp;Kenya&rsquo;s highest peaks &mdash; Nelion,
            Lenana, and Batian &mdash; designed to blend authentic bush charm with luxurious
            comfort. Spacious safari-style suites connect you to nature and serenity.
          </p>
          <p>
            As evening falls, the paths between tents glow softly under solar-powered lamps,
            lighting the way like fireflies in the dusk. At the heart of each village is a shared
            bonfire pit, where the magic of Mtalii truly comes alive &mdash; guests gather to share
            stories, laughter, roasted treats and quiet stargazing moments. A natural meeting point
            where strangers become friends.
          </p>
        </div>
      </div>
    </header>

    <!-- Peak labels strip -->
    <div class="reveal reveal--fade-up grid grid-cols-3 gap-px bg-coffee/15 mb-16 md:mb-20" style="--reveal-delay:120ms;">
      {peaks.map((peak) => (
        <div class="bg-cream p-6 md:p-9 text-center">
          <span class="font-body text-[0.66rem] font-semibold uppercase tracking-[0.32em] text-coffee-light">
            {peak.num}
          </span>
          <h3 class="mt-3 font-display italic text-3xl md:text-5xl text-forest">{peak.name}</h3>
          <p class="mt-2 font-body uppercase tracking-[0.24em] text-[0.66rem] text-coffee">{peak.subtitle}</p>
        </div>
      ))}
    </div>

    <!-- Tent imagery — irregular three-up that reads as a small editorial layout -->
    <div class="grid grid-cols-12 gap-4 md:gap-6">
      <figure class="reveal reveal--scale-image col-span-12 md:col-span-7 relative overflow-hidden aspect-[5/4]">
        <Image src={tentExterior} alt="Safari tented suite exterior at golden hour" widths={[640, 960, 1280, 1600]} sizes="(min-width:768px) 58vw, 100vw" quality={80} format="webp" loading="lazy" class="absolute inset-0 h-full w-full object-cover" />
      </figure>
      <figure class="reveal reveal--scale-image col-span-6 md:col-span-5 relative overflow-hidden aspect-[4/5]" style="--reveal-delay:120ms;">
        <Image src={tentHottub} alt="Private deck with outdoor soaking tub at a Mtalii tented suite" widths={[480, 720, 960]} sizes="(min-width:768px) 40vw, 50vw" quality={80} format="webp" loading="lazy" class="absolute inset-0 h-full w-full object-cover" />
      </figure>
      <figure class="reveal reveal--scale-image col-span-6 md:col-span-12 relative overflow-hidden aspect-[16/9]" style="--reveal-delay:200ms;">
        <Image src={tentInterior} alt="Tented suite interior with king bed and lantern-lit canvas" widths={[640, 1024, 1440, 1920]} sizes="100vw" quality={80} format="webp" loading="lazy" class="absolute inset-0 h-full w-full object-cover" />
      </figure>
    </div>

    <!-- Tent features grid -->
    <div class="mt-20 md:mt-28">
      <div class="reveal reveal--fade-up flex items-center justify-center mb-10">
        <Kicker tone="coffee">Inside Each Tent</Kicker>
      </div>
      <IconGrid items={features} tone="cream" columns={4} />
    </div>
  </div>
</section>
