---
import Kicker from '../Kicker.astro';
import TentMotif from '../TentMotif.astro';
---
<section id="team" class="relative bg-cream py-24 md:py-32">
  <div class="mx-auto max-w-3xl px-6 md:px-10 text-center">
    <div class="reveal reveal--fade flex justify-center">
      <TentMotif size={44} tone="coffee" />
    </div>
    <div class="reveal reveal--fade-up mt-6"><Kicker tone="coffee">The People of Mtalii</Kicker></div>
    <h2 class="reveal reveal--fade-up mt-8 font-display text-display-md text-forest text-balance" style="--reveal-delay:100ms;">
      Our greatest strength is our people.
    </h2>
    <p class="reveal reveal--fade-up mt-7 font-display italic text-xl md:text-2xl text-coffee leading-snug text-balance" style="--reveal-delay:200ms;">
      A passionate team of hospitality professionals, adventure curators and nature enthusiasts
      &mdash; dedicated to creating unforgettable experiences. You&rsquo;re not just a guest;
      you&rsquo;re part of our story.
    </p>
    <span class="reveal reveal--fade hairline mt-12 max-w-xs mx-auto" style="--reveal-delay:300ms;"></span>
  </div>
</section>
