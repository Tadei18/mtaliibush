---
import Kicker from '../Kicker.astro';
import TentMotif from '../TentMotif.astro';
import CTAButton from '../CTAButton.astro';
import Slideshow from '../Slideshow.astro';
import slide01 from '../../assets/story/slide-01.jpg';
import slide02 from '../../assets/story/slide-02.jpg';
import slide03 from '../../assets/story/slide-03.jpg';
import slide04 from '../../assets/story/slide-04.jpg';

const slides = [
  { image: slide01, alt: 'A moment from life at Mtalii Bush Camps', caption: 'Mornings begin slow — light over the mountain, then coffee on the lawn.' },
  { image: slide02, alt: 'A moment from life at Mtalii Bush Camps', caption: 'Long lunches under the trees, the kind that drift into afternoons.' },
  { image: slide03, alt: 'A moment from life at Mtalii Bush Camps', caption: 'Evenings shared around the fire, the night sky overhead.' },
  { image: slide04, alt: 'A moment from life at Mtalii Bush Camps', caption: 'The road home — for now.' },
];
---
<section id="welcome" class="relative bg-cream py-20 md:py-28 scroll-mt-24">
  <div class="mx-auto max-w-wide px-6 md:px-10">
    <div class="grid items-center gap-12 md:gap-16 lg:gap-20 md:grid-cols-12">
      <!-- Intro copy -->
      <div class="md:col-span-5">
        <div class="reveal reveal--fade-up flex items-center gap-3">
          <TentMotif tone="coffee" size={30} />
          <Kicker tone="coffee">Our Story</Kicker>
        </div>
        <h2 class="reveal reveal--fade-up mt-6 font-display text-display-md text-forest text-balance" style="--reveal-delay:100ms;">
          Born from a love of the open road, the mountain, and the morning light.
        </h2>
        <p class="reveal reveal--fade-up mt-7 prose-editorial" style="--reveal-delay:200ms;">
          <span class="block text-[1.075rem] leading-[1.78] text-ink-soft">
            Inspired by a love for the open road, our founders journeyed to Nanyuki and were
            captivated by the crisp air and the majestic presence of Mount Kenya. What began as a
            personal retreat became a mission to share that magic &mdash; where adventure meets
            comfort, and strangers become friends around the fire.
          </span>
        </p>
        <div class="reveal reveal--fade-up mt-9" style="--reveal-delay:300ms;">
          <CTAButton href="/story" variant="outline" tone="cream">Read our story</CTAButton>
        </div>
      </div>

      <!-- Integrated "Moments at Mtalii" slideshow — smaller, beside the copy -->
      <div class="md:col-span-7">
        <div class="reveal reveal--fade-up" style="--reveal-delay:200ms;">
          <p class="mb-5 flex items-center gap-3 font-body text-[0.66rem] font-semibold uppercase tracking-[0.28em] text-coffee-light">
            <span class="block h-px w-8 bg-current opacity-50"></span>
            Moments at Mtalii
          </p>
          <Slideshow slides={slides} interval={5000} aspect="3/2" compact rounded />
        </div>
      </div>
    </div>
  </div>
</section>
