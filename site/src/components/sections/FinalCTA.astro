---
import { Image } from 'astro:assets';
import CTAButton from '../CTAButton.astro';
import Kicker from '../Kicker.astro';
import heroImage from '../../assets/hero/hero-mt-kenya.jpg';

const email = 'marketing@mtaliibushcamps.com';
const phone1 = '+254 718 045 869';
const phone2 = '+254 702 531 835';
---
<section id="enquire" class="relative isolate overflow-hidden bg-forest-deep text-cream py-28 md:py-40">
  <!-- Background photo at low opacity -->
  <Image
    src={heroImage}
    alt=""
    widths={[960, 1440, 1920]}
    sizes="100vw"
    quality={75}
    format="webp"
    loading="lazy"
    class="absolute inset-0 -z-10 h-full w-full object-cover opacity-30"
  />
  <span class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-b from-forest-deep/85 via-forest-deep/80 to-forest-deep"></span>

  <div class="relative mx-auto max-w-wide px-6 md:px-10">
    <div class="max-w-3xl">
      <div class="reveal reveal--fade-up"><Kicker tone="sand">Your Next Chapter</Kicker></div>
      <h2 class="reveal reveal--fade-up mt-7 font-display text-display-lg md:text-display-xl text-cream text-balance" style="--reveal-delay:100ms;">
        Start your next unforgettable chapter with us.
      </h2>
      <p class="reveal reveal--fade-up mt-7 font-display italic text-xl md:text-2xl text-sand/95 leading-snug text-balance" style="--reveal-delay:200ms;">
        Tell us about your trip &mdash; whether it&rsquo;s a long weekend under canvas, a corporate
        retreat in the hills, or a wedding under the stars. We&rsquo;ll shape it around you.
      </p>
      <div class="reveal reveal--fade-up mt-10 flex flex-col sm:flex-row gap-4" style="--reveal-delay:300ms;">
        <CTAButton href="/contact" variant="primary" tone="dark">Begin Your Enquiry</CTAButton>
        <CTAButton href={`mailto:${email}`} variant="outline" tone="dark">Email Us</CTAButton>
      </div>
    </div>

    <span class="hairline-sand block w-full mt-16 md:mt-24 opacity-50"></span>

    <!-- Contact band -->
    <div class="grid gap-12 md:grid-cols-3 mt-14">
      <div class="reveal reveal--fade-up">
        <p class="font-body uppercase tracking-[0.32em] text-[0.66rem] text-sand mb-4">Reach Us</p>
        <a href={`mailto:${email}`} class="block font-display text-2xl text-cream hover:text-sand transition-colors break-words">{email}</a>
        <div class="mt-4 space-y-2 font-body text-cream/80">
          <a href={`tel:${phone1.replace(/\s+/g, '')}`} class="block hover:text-sand transition-colors">{phone1}</a>
          <a href={`tel:${phone2.replace(/\s+/g, '')}`} class="block hover:text-sand transition-colors">{phone2}</a>
        </div>
      </div>
      <div class="reveal reveal--fade-up" style="--reveal-delay:120ms;">
        <p class="font-body uppercase tracking-[0.32em] text-[0.66rem] text-sand mb-4">Find Us</p>
        <p class="font-display text-2xl text-cream leading-tight">Nanyuki, Kenya</p>
        <p class="mt-3 font-body text-cream/80 leading-relaxed">
          Opposite Nanyuki Airstrip<br />Laikipia &middot; Mt.&nbsp;Kenya Foothills
        </p>
      </div>
      <div class="reveal reveal--fade-up" style="--reveal-delay:240ms;">
        <p class="font-body uppercase tracking-[0.32em] text-[0.66rem] text-sand mb-4">Open Daily</p>
        <p class="font-display text-2xl text-cream leading-tight">Year-round</p>
        <p class="mt-3 font-body text-cream/80 leading-relaxed">
          Best months: June &ndash; October &amp; January &ndash; February. The mountain rewards
          early risers.
        </p>
      </div>
    </div>
  </div>
</section>
