---
import { Image } from 'astro:assets';
import Kicker from '../Kicker.astro';
import poolAerial from '../../assets/pool/guitar-pool-aerial.jpg';

// Only true facilities drawn from existing site content. The guitar-shaped pool
// is the camp's signature asset, so it gets a photographic feature card rather
// than a single grid icon (see the teaser beside this grid).
const amenities = [
  { icon: 'spa', label: 'Casadra Spa & Wellness' },
  { icon: 'gym', label: 'Eco-Gym Studio' },
  { icon: 'target', label: 'Archery' },
  { icon: 'horse', label: 'Scenic Horse Riding' },
  { icon: 'quad', label: 'Quad Biking' },
  { icon: 'flame', label: 'Bonfire Evenings' },
  { icon: 'dice', label: 'Board Games Lounge' },
  { icon: 'chat', label: 'WhatsApp Concierge' },
  { icon: 'parking', label: 'Free Parking' },
];

const ICONS: Record<string, string> = {
  spa: '<path d="M12 21V11"/><path d="M12 11c-2.5-3.5-6-3.2-6-.6 0 2.5 3.4 5 6 5.8 2.6-.8 6-3.3 6-5.8 0-2.6-3.5-2.9-6 .6z"/>',
  gym: '<path d="M4 9v6M7 7v10M17 7v10M20 9v6M7 12h10"/>',
  target: '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.4" fill="currentColor"/>',
  horse: '<path d="M14 4l3 1-1 3-2 1-2 3v3l2 3-2 3h-3l-1-3-3-2v-3l-2-2 1-3 3-1 2-3z"/>',
  quad: '<circle cx="6.5" cy="16" r="2.5"/><circle cx="17.5" cy="16" r="2.5"/><path d="M4 13l2-5h6l3 4h5l-1 4"/>',
  flame: '<path d="M12 3c2 4 5 5 5 9a5 5 0 0 1-10 0c0-2 1-3 2-4-.5 2 .5 3 2 3 0-3 1-5 1-8z"/>',
  dice: '<rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8" cy="8" r="1" fill="currentColor"/><circle cx="16" cy="16" r="1" fill="currentColor"/><circle cx="16" cy="8" r="1" fill="currentColor"/><circle cx="8" cy="16" r="1" fill="currentColor"/>',
  chat: '<path d="M21 11.5a8.38 8.38 0 0 1-12.36 7.36L3 21l2.14-5.64A8.38 8.38 0 1 1 21 11.5z"/>',
  parking: '<rect x="4" y="4" width="16" height="16" rx="3"/><path d="M9 16V8h3.2a2.4 2.4 0 0 1 0 4.8H9"/>',
};
---
<section id="amenities" class="relative bg-cream py-24 md:py-32 scroll-mt-24">
  <div class="mx-auto max-w-wide px-6 md:px-10">
    <header class="mb-14 md:mb-20 max-w-2xl">
      <div class="reveal reveal--fade-up"><Kicker tone="coffee">Facilities & Wellness</Kicker></div>
      <h2 class="reveal reveal--fade-up mt-6 font-display text-display-lg text-forest text-balance" style="--reveal-delay:100ms;">
        Everything the camp holds, within easy reach.
      </h2>
    </header>

    <div class="grid gap-7 lg:grid-cols-12 lg:items-stretch">
      <!-- Pool feature teaser — the signature asset, kept photographic -->
      <article class="reveal reveal--fade-up group lg:col-span-5">
        <a href="/stay#pool" class="relative block h-full min-h-[20rem] overflow-hidden rounded-feature bg-forest-deep focus-visible:outline focus-visible:outline-2 focus-visible:outline-sand focus-visible:outline-offset-4">
          <Image
            src={poolAerial}
            alt="Aerial view of the guitar-shaped infinity pool at Mtalii Bush Camps"
            widths={[480, 720, 1024]}
            sizes="(min-width: 1024px) 40vw, 100vw"
            quality={82}
            format="webp"
            loading="lazy"
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-[1400ms] ease-editorial group-hover:scale-[1.05]"
          />
          <span class="pointer-events-none absolute inset-0 bg-gradient-to-t from-forest-deep/90 via-forest-deep/30 to-transparent"></span>
          <div class="absolute inset-x-7 bottom-7">
            <p class="font-body text-[0.62rem] font-semibold uppercase tracking-[0.3em] text-sand">Signature</p>
            <h3 class="mt-2 font-display text-display-sm text-cream text-balance">The guitar-shaped infinity pool</h3>
            <p class="mt-3 max-w-sm font-body text-cream/85 leading-relaxed">
              Pool gardens &amp; private cabanas, tuned to Mt.&nbsp;Kenya &mdash; with 4pm teas and
              long Sunday brunches.
            </p>
            <span class="mt-5 inline-flex items-center gap-2 font-body text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-cream">
              Discover the pool gardens
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="transition-transform duration-500 ease-editorial group-hover:translate-x-1"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
        </a>
      </article>

      <!-- Amenities icon grid -->
      <div class="lg:col-span-7">
        <ul class="grid grid-cols-2 sm:grid-cols-3 gap-px overflow-hidden rounded-card bg-coffee/12">
          {amenities.map((item, i) => (
            <li
              class="reveal reveal--fade-up group flex flex-col items-start gap-4 bg-cream p-6 md:p-7 transition-colors duration-500 ease-editorial hover:bg-mist"
              style={`--reveal-delay:${(i % 3) * 80}ms;`}
            >
              <span class="flex h-11 w-11 items-center justify-center rounded-full border border-coffee/25 text-forest transition-colors duration-500 group-hover:border-sand group-hover:bg-sand group-hover:text-ink">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[item.icon]} />
              </span>
              <span class="font-display text-lg leading-tight text-forest">{item.label}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
