---
import { Image } from 'astro:assets';
import Kicker from '../Kicker.astro';
import TentMotif from '../TentMotif.astro';
import storyImage from '../../assets/hero/hero-mt-kenya.jpg';
---
<section id="story" class="bg-cream">
  <!-- Image-backed heading band -->
  <div class="relative isolate overflow-hidden bg-forest-deep text-cream min-h-[80svh] md:min-h-[640px]">
    <div class="absolute inset-0 z-0">
      <Image
        src={storyImage}
        alt="Mtalii tented camp glowing at golden hour beneath Mount Kenya"
        widths={[960, 1440, 1920, 2400]}
        sizes="100vw"
        quality={82}
        format="webp"
        loading="lazy"
        class="absolute inset-0 h-full w-full object-cover"
      />
    </div>

    <!-- Scrim — subtle on top, deeper at the bottom to anchor the heading -->
    <span class="pointer-events-none absolute inset-0 z-10 bg-gradient-to-b from-forest-deep/55 via-forest-deep/35 to-forest-deep/85"></span>
    <span class="pointer-events-none absolute inset-x-0 bottom-0 z-10 h-2/3 bg-gradient-to-t from-forest-deep/85 via-forest-deep/40 to-transparent"></span>
    <span class="pointer-events-none absolute inset-0 z-10 bg-[radial-gradient(80%_60%_at_50%_120%,rgba(15,68,35,0.55),transparent_60%)]"></span>

    <div class="relative z-20 flex min-h-[80svh] md:min-h-[640px] flex-col justify-end px-6 md:px-10 pt-28 md:pt-36 pb-16 md:pb-24">
      <div class="mx-auto w-full max-w-wide">
        <div class="reveal reveal--fade-up max-w-3xl">
          <Kicker tone="sand">Our Story</Kicker>
        </div>
        <h2 class="reveal reveal--fade-up mt-7 font-display text-display-md md:text-display-lg text-cream text-balance max-w-4xl" style="--reveal-delay:120ms;">
          Born from a love of the open road, the mountain, and the morning light.
        </h2>
        <div class="reveal reveal--fade mt-10 flex items-center gap-4 max-w-xs" style="--reveal-delay:240ms;">
          <TentMotif size={36} tone="sand" />
          <span class="hairline-sand flex-1 opacity-60"></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Body prose band -->
  <div class="relative bg-cream py-20 md:py-28">
    <div class="mx-auto max-w-wide px-6 md:px-10">
      <div class="grid gap-14 md:gap-20 md:grid-cols-12">
        <div class="md:col-span-7 prose-editorial">
          <div class="reveal reveal--fade-up">
            <p>
              Mtalii Bush Camps began with a shared vision of adventure. Inspired by a love for the
              open road, our founders journeyed to Nanyuki in a 4x4, seeking the freedom of the
              mountains. They were immediately captivated by the crisp air and the majestic
              presence of Mount Kenya.
            </p>
            <p>
              What started as a personal retreat evolved into a mission to share this magic with
              the world. Today, Mtalii Bush Camps is where adventure meets comfort &mdash; whether
              you&rsquo;re here for a challenging climb, a corporate retreat, or a peaceful escape,
              we invite you to start your next unforgettable chapter with us.
            </p>
          </div>
        </div>
        <div class="md:col-span-5">
          <span class="reveal reveal--fade hairline block w-full md:mt-3"></span>
          <p class="reveal reveal--fade-up mt-7 font-display italic text-2xl md:text-3xl text-coffee leading-snug text-balance" style="--reveal-delay:120ms;">
            &ldquo;Strangers become friends &mdash; around the same fire, beneath the same
            mountain.&rdquo;
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
