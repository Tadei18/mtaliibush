---
import { Image } from 'astro:assets';
import Kicker from '../Kicker.astro';
import TentMotif from '../TentMotif.astro';
import eveningGlow from '../../assets/accommodation/evening-glow.jpg';
---
<section id="directors-message" class="relative bg-mist py-24 md:py-36">
  <div class="mx-auto max-w-wide px-6 md:px-10">
    <div class="grid items-center gap-14 md:gap-20 md:grid-cols-12">
      <div class="reveal reveal--scale-image md:col-span-6">
        <div class="relative overflow-hidden aspect-[4/5] shadow-soft">
          <Image
            src={eveningGlow}
            alt="An intimate evening at Mtalii Bush Camps, lit by lanterns and the last light of day"
            widths={[640, 960, 1280]}
            sizes="(min-width: 768px) 50vw, 100vw"
            quality={82}
            format="webp"
            loading="lazy"
            class="absolute inset-0 h-full w-full object-cover"
          />
          <span class="pointer-events-none absolute inset-0 bg-gradient-to-tr from-ink/25 via-transparent to-transparent"></span>
        </div>
      </div>

      <div class="md:col-span-6">
        <div class="reveal reveal--fade-up flex items-center gap-3">
          <TentMotif tone="coffee" size={32} />
          <Kicker tone="coffee">Director&rsquo;s Message</Kicker>
        </div>
        <h2 class="reveal reveal--fade-up mt-7 font-display text-display-md text-forest text-balance" style="--reveal-delay:100ms;">
          More than a journey &mdash; an invitation to connect.
        </h2>
        <div class="reveal reveal--fade-up mt-8 prose-editorial" style="--reveal-delay:200ms;">
          <p>
            At Mtalii Bush Camps, we believe travel is more than just a journey &mdash; it is an
            experience that connects you with nature, culture, and unforgettable moments. Our mission
            is to offer you a unique blend of comfort and authenticity, right in the heart of the wild.
          </p>
          <p>
            Every stay with us is thoughtfully designed to bring you closer to nature while ensuring
            the highest standards of hospitality. From serene landscapes to warm campfire evenings, we
            are committed to creating memories that last a lifetime.
          </p>
          <p>
            We invite you to escape the ordinary, embrace the adventure, and discover the beauty of
            Africa with us.
          </p>
        </div>
        <p class="reveal reveal--fade-up mt-9 font-body uppercase tracking-[0.32em] text-[0.72rem] text-coffee-light" style="--reveal-delay:300ms;">
          &mdash; The Director, Mtalii Bush Camps
        </p>
      </div>
    </div>
  </div>
</section>
