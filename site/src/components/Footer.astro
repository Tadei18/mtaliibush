---
import Logo from './Logo.astro';

const year = new Date().getFullYear();
const phone1 = '+254 718 045 869';
const phone2 = '+254 702 531 835';
const email = 'marketing@mtaliibushcamps.com';
---
<footer class="relative bg-forest-deep text-cream/90">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-sand/40 to-transparent"></div>
  <div class="mx-auto max-w-wide px-6 md:px-10 py-20 md:py-28">
    <div class="grid gap-12 md:grid-cols-12">
      <div class="md:col-span-4">
        <Logo variant="light" size={72} />
        <p class="mt-7 font-display italic text-xl text-sand leading-snug max-w-xs">
          Where adventure meets purpose at the foothills of majesty.
        </p>
      </div>

      <div class="md:col-span-2">
        <h4 class="font-body uppercase tracking-[0.22em] text-[0.7rem] text-sand mb-5">Discover</h4>
        <ul class="space-y-3 font-body text-cream/80">
          <li><a href="/stay" class="hover:text-sand transition-colors">Stay</a></li>
          <li><a href="/dine" class="hover:text-sand transition-colors">Dine</a></li>
          <li><a href="/experiences" class="hover:text-sand transition-colors">Experiences</a></li>
          <li><a href="/events" class="hover:text-sand transition-colors">Meetings &amp; Events</a></li>
          <li><a href="/gallery" class="hover:text-sand transition-colors">Gallery</a></li>
          <li><a href="/story" class="hover:text-sand transition-colors">Our Story</a></li>
        </ul>
      </div>

      <div class="md:col-span-3">
        <h4 class="font-body uppercase tracking-[0.22em] text-[0.7rem] text-sand mb-5">Reach Us</h4>
        <ul class="space-y-3 font-body text-cream/80">
          <li>
            <a href={`mailto:${email}`} class="hover:text-sand transition-colors break-words">{email}</a>
          </li>
          <li><a href={`tel:${phone1.replace(/\s+/g, '')}`} class="hover:text-sand transition-colors">{phone1}</a></li>
          <li><a href={`tel:${phone2.replace(/\s+/g, '')}`} class="hover:text-sand transition-colors">{phone2}</a></li>
        </ul>
      </div>

      <div class="md:col-span-3">
        <h4 class="font-body uppercase tracking-[0.22em] text-[0.7rem] text-sand mb-5">Find Us</h4>
        <p class="font-body text-cream/80 leading-relaxed">
          Nanyuki, Kenya<br />
          Opposite Nanyuki Airstrip<br />
          Laikipia, Mt. Kenya Foothills
        </p>
        <div class="mt-6 flex items-center gap-4">
          <!-- TODO: Replace # with real Instagram URL -->
          <a href="#" aria-label="Instagram" class="text-cream/70 hover:text-sand transition-colors">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="4"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.8" fill="currentColor"/></svg>
          </a>
          <!-- TODO: Replace # with real Facebook URL -->
          <a href="#" aria-label="Facebook" class="text-cream/70 hover:text-sand transition-colors">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 8h2.5V5H14c-1.7 0-3 1.3-3 3v2H9v3h2v8h3v-8h2.3l.7-3H14V8z"/></svg>
          </a>
          <!-- WhatsApp uses first phone number -->
          <a href={`https://wa.me/${phone1.replace(/\D/g, '')}`} aria-label="WhatsApp" class="text-cream/70 hover:text-sand transition-colors">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 11.5a8.38 8.38 0 0 1-12.36 7.36L3 21l2.14-5.64A8.38 8.38 0 1 1 21 11.5z"/><path d="M8.5 9.5c.4-.5 1.2-.6 1.8-.2.5.3.7.9.9 1.4.2.6-.4 1.1-.7 1.4-.2.2 0 .5.3.9.5.7 1.4 1.4 2.4 1.7.5.1.8 0 1-.3.3-.4.7-.7 1.2-.5.5.2 1.6.8 1.7 1.4.1.6-.7 1.2-1.2 1.4-1 .5-2.2.3-3.3-.2-1.6-.7-3-2-3.9-3.5-.6-1-1.1-2.3-.2-3.5z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <hr class="my-12 border-cream/15" />

    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-5 text-[0.78rem] font-body text-cream/60 uppercase tracking-[0.18em]">
      <p>&copy; {year} Mtalii Bush Camps. All rights reserved.</p>
      <p class="not-italic">Crafted in Nanyuki · Mt. Kenya, Kenya</p>
    </div>
  </div>
</footer>
