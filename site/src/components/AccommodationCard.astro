---
import { Image } from 'astro:assets';

interface Chip {
  icon: string;
  label: string;
}
interface Props {
  image: ImageMetadata;
  alt: string;
  number: string;
  name: string;
  subtitle: string;
  chips: Chip[];
  detailsHref?: string;
  enquireHref?: string;
}
const {
  image,
  alt,
  number,
  name,
  subtitle,
  chips,
  detailsHref = '/stay',
  enquireHref = '/contact?interest=Stay',
} = Astro.props;

const CHIP_ICONS: Record<string, string> = {
  bed: '<path d="M3 18V8"/><path d="M3 13h18v5"/><path d="M21 13v-3a3 3 0 0 0-3-3h-7v6"/><circle cx="7" cy="11" r="1.5"/>',
  bath: '<path d="M3 12h18v3a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4z"/><path d="M5 12V6a2 2 0 0 1 4 0"/>',
  shower: '<path d="M4 20v-7a6 6 0 0 1 12 0M16 7a3 3 0 0 1 4 3v3"/><path d="M9 17v1M12 18v1M15 17v1"/>',
  deck: '<path d="M3 10l9-5 9 5"/><path d="M5 10v9M19 10v9M5 19h14M9 19v-5h6v5"/>',
};
---
<article class="acc-card reveal reveal--fade-up group flex flex-col overflow-hidden rounded-card border border-coffee/12 bg-cream shadow-lift transition-all duration-500 ease-editorial hover:-translate-y-1.5 hover:shadow-soft">
  <!-- Image -->
  <div class="relative aspect-[4/3] overflow-hidden bg-mist">
    <Image
      src={image}
      alt={alt}
      widths={[480, 720, 960]}
      sizes="(min-width: 1024px) 30vw, (min-width: 640px) 45vw, 90vw"
      quality={80}
      format="webp"
      loading="lazy"
      class="absolute inset-0 h-full w-full object-cover transition-transform duration-[1200ms] ease-editorial group-hover:scale-[1.06]"
    />
    <span class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink/55 via-ink/5 to-transparent"></span>
    <span class="absolute left-5 top-5 font-body text-[0.62rem] font-semibold uppercase tracking-[0.32em] text-cream/90">
      {number}
    </span>
    <div class="absolute inset-x-5 bottom-4">
      <h3 class="font-display text-3xl text-cream leading-tight drop-shadow-sm">{name}</h3>
      <p class="mt-0.5 font-body text-[0.66rem] uppercase tracking-[0.24em] text-sand">{subtitle}</p>
    </div>
  </div>

  <!-- Body -->
  <div class="flex flex-1 flex-col p-6 md:p-7">
    <p class="font-body text-[0.95rem] leading-relaxed text-ink/75">
      <slot />
    </p>

    <!-- Feature chips -->
    <ul class="mt-6 flex flex-wrap gap-2">
      {chips.map((chip) => (
        <li class="inline-flex items-center gap-1.5 rounded-full border border-coffee/15 bg-mist px-3 py-1.5">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#186030" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={CHIP_ICONS[chip.icon] ?? CHIP_ICONS.bed} />
          <span class="font-body text-[0.66rem] font-semibold uppercase tracking-[0.08em] text-coffee">{chip.label}</span>
        </li>
      ))}
    </ul>

    <!-- CTAs -->
    <div class="mt-7 flex flex-wrap items-center gap-x-6 gap-y-3 border-t border-coffee/10 pt-5">
      <a href={detailsHref} class="group/cta inline-flex items-center gap-2 font-body text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-forest transition-colors hover:text-coffee">
        View Details
        <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="transition-transform duration-500 ease-editorial group-hover/cta:translate-x-1">
          <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href={enquireHref} class="inline-flex items-center gap-2 rounded-full bg-sand px-5 py-2.5 font-body text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-ink transition-colors hover:bg-sand-deep">
        Enquire
      </a>
    </div>
  </div>
</article>
