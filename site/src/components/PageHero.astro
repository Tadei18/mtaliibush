---
import { Image } from 'astro:assets';
import Kicker from './Kicker.astro';

interface Props {
  /** Imported background image (from src/assets/...). */
  image: ImageMetadata;
  /** Alt text for the background image. */
  alt: string;
  /** Small caps eyebrow above the headline. */
  kicker: string;
  /** Main page headline. */
  title: string;
  /** Optional supporting line shown beneath the headline. */
  tagline?: string;
  /** Optional crumb path shown above the kicker. */
  crumb?: string;
}
const { image, alt, kicker, title, tagline, crumb } = Astro.props;
---
<section class="relative isolate overflow-hidden bg-forest-deep text-cream h-[72svh] min-h-[520px] max-h-[760px]" data-hero-parallax>
  <div class="hero-bg absolute inset-0 z-0 will-change-transform">
    <Image
      src={image}
      alt={alt}
      widths={[960, 1440, 1920, 2400]}
      sizes="100vw"
      quality={80}
      format="webp"
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 h-[112%] w-full object-cover animate-subtle-zoom"
    />
  </div>

  <span class="pointer-events-none absolute inset-0 z-10 bg-[radial-gradient(100%_70%_at_50%_100%,rgba(15,68,35,0.65),transparent_70%)]"></span>
  <span class="pointer-events-none absolute inset-x-0 top-0 z-10 h-40 bg-gradient-to-b from-forest-deep/75 to-transparent"></span>
  <span class="pointer-events-none absolute inset-x-0 bottom-0 z-10 h-1/2 bg-gradient-to-t from-forest-deep/85 via-forest-deep/35 to-transparent"></span>

  <div class="relative z-20 flex h-full items-end pb-16 md:pb-24">
    <div class="mx-auto w-full max-w-wide px-6 md:px-10">
      {crumb && (
        <p class="reveal reveal--fade-up font-body text-[0.66rem] uppercase tracking-[0.32em] text-cream/65">
          <a href="/" class="hover:text-sand transition-colors">Mtalii Bush Camps</a>
          <span aria-hidden="true" class="mx-3 opacity-60">/</span>
          <span class="text-sand">{crumb}</span>
        </p>
      )}
      <div class="reveal reveal--fade-up mt-5" style="--reveal-delay:120ms;">
        <Kicker tone="sand">{kicker}</Kicker>
      </div>
      <h1 class="reveal reveal--fade-up mt-7 font-display text-display-lg md:text-display-xl text-cream text-balance max-w-4xl" style="--reveal-delay:240ms;">
        {title}
      </h1>
      {tagline && (
        <p class="reveal reveal--fade-up mt-6 max-w-2xl font-display italic text-xl md:text-2xl text-cream/90 leading-snug text-balance" style="--reveal-delay:360ms;">
          {tagline}
        </p>
      )}
    </div>
  </div>
</section>
