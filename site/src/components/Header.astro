---
import Logo from './Logo.astro';
import CTAButton from './CTAButton.astro';

const nav = [
  { href: '/stay', label: 'Stay' },
  { href: '/dine', label: 'Dine' },
  { href: '/experiences', label: 'Experiences' },
  { href: '/events', label: 'Events' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/contact', label: 'Contact' },
];

// Active-page indicator — normalise trailing slashes, then match by path.
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) => path === href || path.startsWith(`${href}/`);

const phone = '+254 718 045 869';
const waNumber = '254718045869';
const waMessage = "Hello Mtalii Bush Camps, I'd like to enquire about a stay.";
---
<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 ease-editorial"
  data-state="top"
>
  <div class="mx-auto flex max-w-wide items-center justify-between px-6 md:px-10 py-5">
    <div class="site-header__logo relative">
      <span class="logo-swap logo-swap--light" data-when="top">
        <Logo variant="light" size={44} eager />
      </span>
      <span class="logo-swap logo-swap--dark" data-when="scrolled" aria-hidden="true">
        <Logo variant="dark" size={44} eager />
      </span>
    </div>

    <nav class="hidden lg:flex items-center gap-9" aria-label="Primary">
      {nav.map((item) => {
        const active = isActive(item.href);
        return (
          <a
            href={item.href}
            aria-current={active ? 'page' : undefined}
            data-active={active ? 'true' : undefined}
            class="nav-link group relative font-body text-[0.78rem] uppercase tracking-[0.22em] text-cream/90 hover:text-cream transition-colors"
          >
            <span>{item.label}</span>
            <span class={`nav-underline absolute -bottom-1 left-0 h-px bg-sand transition-all duration-500 ease-editorial group-hover:w-full ${active ? 'w-full' : 'w-0'}`}></span>
          </a>
        );
      })}
    </nav>

    <div class="hidden lg:block">
      <CTAButton href="/contact" variant="primary" tone="dark">Enquire</CTAButton>
    </div>

    <button
      type="button"
      id="menu-toggle"
      aria-label="Open menu"
      aria-controls="mobile-menu"
      aria-expanded="false"
      class="lg:hidden relative z-50 flex h-11 w-11 items-center justify-center text-cream"
    >
      <span class="sr-only">Menu</span>
      <span class="menu-bars" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>
  </div>
</header>

<!-- Mobile overlay menu -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-forest-deep text-cream pointer-events-none opacity-0 transition-opacity duration-500 ease-editorial"
  aria-hidden="true"
>
  <div class="absolute inset-0 bg-[radial-gradient(120%_80%_at_50%_0%,rgba(228,192,132,0.15),transparent_60%)]"></div>
  <nav class="relative h-full flex flex-col items-center justify-center gap-7 px-6 text-center" aria-label="Mobile">
    {nav.map((item, i) => (
      <a
        href={item.href}
        aria-current={isActive(item.href) ? 'page' : undefined}
        class={`mobile-menu-link font-display text-5xl tracking-tight transition-colors hover:text-sand ${isActive(item.href) ? 'text-sand' : 'text-cream'}`}
        style={`--i:${i}`}
      >
        {item.label}
      </a>
    ))}
    <div class="mt-6"><CTAButton href="/contact" variant="primary" tone="dark">Enquire</CTAButton></div>
  </nav>
</div>

<!-- Mobile sticky bottom bar — Call · WhatsApp · Enquire (phones only) -->
<div id="mobile-bar" class="mobile-bar" data-state="hidden" aria-label="Quick contact">
  <a href={`tel:${phone.replace(/\s+/g, '')}`} class="mobile-bar__item">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 4h3l2 5-2.5 1.5a11 11 0 0 0 5 5L15 12l5 2v3a2 2 0 0 1-2 2A14 14 0 0 1 4 6a2 2 0 0 1 1-2z"/></svg>
    <span>Call</span>
  </a>
  <a href={`https://wa.me/${waNumber}?text=${encodeURIComponent(waMessage)}`} target="_blank" rel="noopener noreferrer" class="mobile-bar__item mobile-bar__item--wa">
    <svg width="20" height="20" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d="M16 3.2c-7.07 0-12.8 5.73-12.8 12.8 0 2.26.6 4.46 1.74 6.4l-1.83 6.69 6.86-1.8A12.7 12.7 0 0 0 16 28.8c7.06 0 12.79-5.73 12.79-12.8 0-3.42-1.33-6.63-3.74-9.04A12.7 12.7 0 0 0 16 3.2zm0 23.36c-1.83 0-3.62-.5-5.18-1.42l-.37-.23-3.83 1.01 1.02-3.74-.24-.38a10.2 10.2 0 0 1-1.56-5.43c0-5.65 4.6-10.25 10.16-10.25 2.73 0 5.29 1.06 7.21 2.99a10.1 10.1 0 0 1 2.99 7.21c0 5.65-4.6 10.24-10.2 10.24zm5.59-7.67c-.3-.15-1.81-.9-2.09-1-.28-.1-.49-.15-.7.15-.2.3-.79.99-.97 1.2-.18.2-.36.23-.66.08-1.81-.9-3-1.62-4.19-3.66-.32-.55.32-.51.91-1.7.1-.21.05-.39-.02-.54-.07-.15-.7-1.67-.95-2.29-.25-.6-.5-.52-.7-.53h-.59c-.21 0-.54.08-.82.38-.28.3-1.07 1.05-1.07 2.56 0 1.51 1.1 2.96 1.25 3.17.15.21 2.16 3.3 5.23 4.62.73.32 1.3.5 1.74.65.73.23 1.39.2 1.92.12.58-.09 1.8-.74 2.06-1.45.25-.71.25-1.32.17-1.45-.07-.12-.27-.2-.57-.35z"/></svg>
    <span>WhatsApp</span>
  </a>
  <a href="/contact" class="mobile-bar__item mobile-bar__item--cta">
    <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 5h16v11H7l-3 3z"/></svg>
    <span>Enquire</span>
  </a>
</div>

<style is:global>
  /* Three-bar hamburger */
  .menu-bars {
    position: relative;
    display: block;
    width: 26px;
    height: 14px;
  }
  .menu-bars span {
    position: absolute;
    left: 0;
    right: 0;
    height: 1.5px;
    background: currentColor;
    border-radius: 1px;
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease, top 0.4s ease;
  }
  .menu-bars span:nth-child(1) { top: 0; }
  .menu-bars span:nth-child(2) { top: 6.5px; }
  .menu-bars span:nth-child(3) { top: 13px; }
  [data-menu-open="true"] .menu-bars span:nth-child(1) { top: 6.5px; transform: rotate(45deg); }
  [data-menu-open="true"] .menu-bars span:nth-child(2) { opacity: 0; }
  [data-menu-open="true"] .menu-bars span:nth-child(3) { top: 6.5px; transform: rotate(-45deg); }

  /* Header chrome states */
  #site-header[data-state="top"] {
    background: linear-gradient(to bottom, rgba(15, 68, 35, 0.45) 0%, rgba(15, 68, 35, 0) 100%);
  }
  #site-header[data-state="scrolled"] {
    background: rgba(251, 245, 236, 0.92);
    backdrop-filter: blur(14px);
    box-shadow: 0 10px 30px -22px rgba(36, 28, 18, 0.25);
  }
  #site-header[data-state="scrolled"] nav a {
    color: #241C12;
  }
  #site-header[data-state="scrolled"] #menu-toggle { color: #186030; }

  /* Logo cross-fade between top (white lockup) and scrolled (colour lockup) */
  .site-header__logo {
    display: inline-block;
    line-height: 0;
  }
  .logo-swap {
    transition: opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1);
    line-height: 0;
  }
  .logo-swap--dark {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
  }
  #site-header[data-state="scrolled"] .logo-swap--light {
    opacity: 0;
    pointer-events: none;
  }
  #site-header[data-state="scrolled"] .logo-swap--dark {
    opacity: 1;
    pointer-events: auto;
  }

  /* Active-page emphasis — keep the link legible in both header states */
  #site-header[data-state="scrolled"] nav a[data-active="true"] { color: #186030; }

  /* Mobile sticky bottom bar (phones only) */
  .mobile-bar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 70;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    background: rgba(251, 245, 236, 0.94);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-top: 1px solid rgba(228, 192, 132, 0.55);
    box-shadow: 0 -10px 30px -18px rgba(36, 28, 18, 0.4);
    padding-bottom: env(safe-area-inset-bottom);
    transform: translateY(110%);
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .mobile-bar[data-state="shown"] { transform: translateY(0); }
  .mobile-bar__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    padding: 0.7rem 0.5rem;
    font-family: 'Mulish', sans-serif;
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #186030;
    text-decoration: none;
    transition: background 0.3s ease;
  }
  .mobile-bar__item + .mobile-bar__item { border-left: 1px solid rgba(96, 60, 12, 0.12); }
  .mobile-bar__item:active { background: rgba(228, 192, 132, 0.25); }
  .mobile-bar__item--wa { color: #128C7E; }
  .mobile-bar__item--cta {
    background: #E4C084;
    color: #241C12;
  }
  .mobile-bar__item:focus-visible { outline: 2px solid #186030; outline-offset: -2px; }
  /* The contact bar is phones-only; the WhatsApp FAB covers tablet/desktop.
     Controlled here (not Tailwind md:hidden) so the is:global base rule can't
     win the cascade and leak the bar onto desktop. */
  @media (min-width: 768px) {
    .mobile-bar { display: none; }
  }
  /* Hide the floating WhatsApp FAB on phones — it's folded into the bar here */
  @media (max-width: 767.98px) {
    .whatsapp-fab { display: none !important; }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-bar { transition: none; }
  }

  /* Mobile menu open */
  body[data-menu-open="true"] #mobile-menu {
    pointer-events: auto;
    opacity: 1;
  }
  body[data-menu-open="true"] { overflow: hidden; }
  .mobile-menu-link {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
    transition-delay: calc(var(--i) * 60ms + 200ms);
  }
  body[data-menu-open="true"] .mobile-menu-link { opacity: 1; transform: translateY(0); }
</style>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('menu-toggle');

  const mobileBar = document.getElementById('mobile-bar');

  const updateHeaderState = () => {
    if (header) {
      const scrolled = window.scrollY > 60;
      header.setAttribute('data-state', scrolled ? 'scrolled' : 'top');
    }
    // Reveal the mobile contact bar once past the hero's booking area, so it
    // never collides with the hero enquiry bar on first paint.
    if (mobileBar) {
      const past = window.scrollY > window.innerHeight * 0.7;
      const menuOpen = document.body.getAttribute('data-menu-open') === 'true';
      mobileBar.setAttribute('data-state', past && !menuOpen ? 'shown' : 'hidden');
    }
  };
  updateHeaderState();
  window.addEventListener('scroll', updateHeaderState, { passive: true });
  window.addEventListener('resize', updateHeaderState, { passive: true });

  toggle?.addEventListener('click', () => {
    const isOpen = document.body.getAttribute('data-menu-open') === 'true';
    const next = !isOpen;
    document.body.setAttribute('data-menu-open', String(next));
    toggle.setAttribute('aria-expanded', String(next));
    toggle.setAttribute('aria-label', next ? 'Close menu' : 'Open menu');
    const menu = document.getElementById('mobile-menu');
    menu?.setAttribute('aria-hidden', String(!next));
    updateHeaderState();
  });

  // Close on link click
  document.querySelectorAll('.mobile-menu-link').forEach((link) => {
    link.addEventListener('click', () => {
      document.body.setAttribute('data-menu-open', 'false');
      toggle?.setAttribute('aria-expanded', 'false');
      document.getElementById('mobile-menu')?.setAttribute('aria-hidden', 'true');
    });
  });
</script>
