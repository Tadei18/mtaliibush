---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Kicker from '../components/Kicker.astro';
import EnquiryForm from '../components/EnquiryForm.astro';
import MapEmbed from '../components/MapEmbed.astro';
import heroImage from '../assets/dining/mt-kenya-terrace.jpg';

const email = 'marketing@mtaliibushcamps.com';
const phone1 = '+254 718 045 869';
const phone2 = '+254 702 531 835';
const waNumber = phone1.replace(/\D/g, '');
---
<BaseLayout
  title="Contact — Plan your stay at Mtalii Bush Camps"
  description="Plan your stay at Mtalii Bush Camps in Nanyuki — opposite Nanyuki Airstrip, at the foothills of Mt. Kenya. Enquire by form, email, phone or WhatsApp."
>
  <PageHero
    image={heroImage}
    alt="A terrace at Mtalii looking out toward Mount Kenya"
    kicker="Plan Your Stay"
    title="Tell us about your trip."
    tagline="We&rsquo;ll shape it around you &mdash; tents, tables, gatherings, and everything between."
    crumb="Contact"
  />

  <section class="relative bg-cream py-24 md:py-36">
    <div class="mx-auto max-w-wide px-6 md:px-10">
      <div class="grid gap-16 md:gap-20 md:grid-cols-12">
        <!-- Form -->
        <div class="md:col-span-7">
          <div class="reveal reveal--fade-up"><Kicker tone="coffee">Enquire</Kicker></div>
          <h2 class="reveal reveal--fade-up mt-7 font-display text-display-md text-forest text-balance" style="--reveal-delay:100ms;">
            Send us a note &mdash; we reply within a business day.
          </h2>
          <div class="reveal reveal--fade-up mt-12" style="--reveal-delay:200ms;">
            <EnquiryForm />
          </div>
        </div>

        <!-- Aside: contact + map -->
        <aside class="md:col-span-5 md:pt-3">
          <div class="reveal reveal--fade-up">
            <Kicker tone="coffee">Direct Lines</Kicker>
          </div>
          <h3 class="reveal reveal--fade-up mt-5 font-display text-2xl text-forest" style="--reveal-delay:100ms;">
            Prefer to call or message?
          </h3>
          <ul class="reveal reveal--fade-up mt-8 space-y-5 font-body text-ink" style="--reveal-delay:200ms;">
            <li>
              <span class="block font-body uppercase tracking-[0.28em] text-[0.66rem] font-semibold text-coffee-light mb-2">Email</span>
              <a href={`mailto:${email}`} class="font-display text-xl text-forest hover:text-coffee transition-colors break-words">{email}</a>
            </li>
            <li>
              <span class="block font-body uppercase tracking-[0.28em] text-[0.66rem] font-semibold text-coffee-light mb-2">Phone</span>
              <a href={`tel:${phone1.replace(/\s+/g, '')}`} class="block font-display text-xl text-forest hover:text-coffee transition-colors">{phone1}</a>
              <a href={`tel:${phone2.replace(/\s+/g, '')}`} class="block mt-1 font-display text-xl text-forest hover:text-coffee transition-colors">{phone2}</a>
            </li>
            <li>
              <span class="block font-body uppercase tracking-[0.28em] text-[0.66rem] font-semibold text-coffee-light mb-2">WhatsApp</span>
              <a href={`https://wa.me/${waNumber}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 font-display text-xl text-forest hover:text-coffee transition-colors">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-12.36 7.36L3 21l2.14-5.64A8.38 8.38 0 1 1 21 11.5z"/></svg>
                {phone1}
              </a>
            </li>
            <li>
              <span class="block font-body uppercase tracking-[0.28em] text-[0.66rem] font-semibold text-coffee-light mb-2">Find Us</span>
              <p class="font-display text-xl text-forest leading-snug">Nanyuki, Kenya</p>
              <p class="mt-2 font-body text-ink/75 leading-relaxed">
                Opposite Nanyuki Airstrip<br />Laikipia &middot; Mt.&nbsp;Kenya Foothills
              </p>
            </li>
          </ul>

          <div class="reveal reveal--fade-up mt-10" style="--reveal-delay:300ms;">
            <MapEmbed aspect="4/3" />
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
