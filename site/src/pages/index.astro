import Story from '../components/sections/Story.astro';
import StoryMoments from '../components/sections/StoryMoments.astro';
import DirectorsMessage from '../components/sections/DirectorsMessage.astro';
import TentedVillages from '../components/sections/TentedVillages.astro';
import Dining from '../components/sections/Dining.astro';
import Lounges from '../components/sections/Lounges.astro';
import PoolGardens from '../components/sections/PoolGardens.astro';
